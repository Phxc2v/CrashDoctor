    <string id="cd_emergency_save_title" text="Emergency save before crash" />
    <string id="cd_emergency_save_hint" text="If the game is about to die, Crash Doctor tries one last SaveAs so you don't lose hours of unsaved progress. Default: ON. Disable only if it interferes with another save-related mod." />
