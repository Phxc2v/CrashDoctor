<?xml version="1.0" encoding="utf-8"?>
<Settings>
  <MaxCrashesShown>20</MaxCrashesShown>
  <DefaultLanguage>auto</DefaultLanguage>
  <ShowRawLogs>false</ShowRawLogs>
  <RulesReloadOnOpen>false</RulesReloadOnOpen>
  <!-- ShowForceCrashButton: when true, the "Force crash (test)" red button appears in the bottom bar.
       It calls kernel32!RaiseException with EXCEPTION_ACCESS_VIOLATION (0xC0000005) so Bannerlord's
       native crash dumper fires and writes a real dump to ProgramData/.../crashes/<ts>/ (which is a
       junction to Modules/CrashDoctor/cache/). For developer/debug use only. -->
  <ShowForceCrashButton>false</ShowForceCrashButton>
  <!-- NEW (2026-05-14) EnableEmergencySave: when an unhandled exception is about to terminate the
       process, try one last SaveAs("CrashDoctor_Emergency_<timestamp>") so the player doesn't lose
       hours of unsaved progress. Default ON. Set false to disable if it interacts badly with
       another save-related mod. The attempt runs AFTER the crash stack trace is already written
       to crashdoctor.log, so disabling it doesn't affect diagnostics. -->
  <EnableEmergencySave>true</EnableEmergencySave>
  <!-- NEW (2026-05-14) EnableNativeCrashLogging: install a Windows Vectored Exception Handler
       that writes one line to crashdoctor.log when a NATIVE crash occurs (access violation,
       stack overflow, heap corruption). Default OFF because VEH is process-global and can
       interact with other mods/debuggers. The handler is observe-only — it does NOT swallow
       the exception, so TaleWorlds' .dmp pipeline keeps working as before. Turn ON if you want
       a timestamp inside crashdoctor.log to correlate with the .dmp folder created by the
       crash dialog. -->
  <EnableNativeCrashLogging>false</EnableNativeCrashLogging>
  <!-- NEW (2026-05-14, Phase 4) EnableUIErrorPatching: wraps a hand-picked list of UI refresh
       methods with Harmony Finalizers so a broken third-party UI patch shows a red message
       instead of crashing the game. Conservative — only methods that can't corrupt save state.
       Default OFF — opt-in via Settings tab in Crash Doctor UI. -->
  <EnableUIErrorPatching>false</EnableUIErrorPatching>
  <!-- NEW (2026-05-21) EnableNreSafetyPatches: install Harmony patches on TOR_Core's
       TORPartyWageModel, TORMobilePartyFoodConsumptionModel and every AiHourlyTick in
       TaleWorlds.CampaignSystem.CampaignBehaviors.AiBehaviors that swallow NREs caused
       by dangling CharacterObject references (a character that was unregistered from
       MBObjectManager but is still sitting in some party's roster). Default ON — pure
       crash prevention, no game-state mutation. Turn OFF only if you suspect these
       patches are interfering with another mod. -->
  <EnableNreSafetyPatches>true</EnableNreSafetyPatches>
  <!-- NEW (2026-05-21) EnableDanglingRosterCleanup: on session launch, scan every party
       / settlement roster and remove troop elements whose Character/Culture is null
       (dangling reference left by another mod that unregistered a CharacterObject
       without scrubbing it from rosters). Without this, the downstream AI tick NREs
       on the dangling element. Default ON — safe and silent when no dangling
       elements are present. -->
  <EnableDanglingRosterCleanup>true</EnableDanglingRosterCleanup>
</Settings>
