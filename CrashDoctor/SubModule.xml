<?xml version="1.0" encoding="utf-8"?>
<Module>
  <Id value="CrashDoctor" />
  <Name value="Crash Doctor" />
  <Version value="v1.4.0" />
  <DefaultModule value="false" />
  <ModuleCategory value="Singleplayer" />
  <ModuleType value="Community" />
  <DependedModules>
    <!-- Floor only. DependentVersion is a MINIMUM, not an exact match: this requires
         Native/SandBox at least v1.3.0, so ANY 1.3.x release is accepted (the engine API
         is stable within the 1.3 minor series, and our DLL is built against 1.3). It
         blocks only older builds (1.2.x) where the DLL would not run. Newer (1.4+) also
         passes this gate — a real upper bound / multi-version build is tracked in
         MULTIVERSION_BUILD_PLAN.md. No third-party mod is listed; no runtime deps. -->
    <DependedModule Id="Native" DependentVersion="v1.3.0" />
    <DependedModule Id="SandBoxCore" DependentVersion="v1.3.0" />
    <DependedModule Id="Sandbox" DependentVersion="v1.3.0" />
  </DependedModules>
  <SubModules>
    <SubModule>
      <Name value="CrashDoctor SubModule" />
      <DLLName value="CrashDoctor.dll" />
      <SubModuleClassType value="CrashDoctor.SubModule" />
      <Tags>
        <Tag key="DedicatedServerType" value="none" />
        <Tag key="IsNoRenderModeElement" value="false" />
      </Tags>
    </SubModule>
  </SubModules>
</Module>
